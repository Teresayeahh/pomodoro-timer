{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "桌面番茄钟",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "番茄钟",
    "files": ["dist/**/*", "electron/**/*"],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    }
  }
}
